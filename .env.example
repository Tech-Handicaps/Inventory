# Database — use Supabase SHARED POOLER (Session mode), not the direct DB host.
# Dashboard: Project Settings → Database → Connection string → Session pooler (port 5432 on pooler host)
# Transaction pooler uses port 6543 instead. Direct `db.<ref>.supabase.co:5432` can fail on IPv4-only paths.
# Placeholders: [YOUR-PASSWORD], [PROJECT-REF], [REGION] (e.g. eu-central-1, us-east-1)
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres?pgbouncer=true&connection_limit=1"

# Supabase (for Auth, optional client)
NEXT_PUBLIC_SUPABASE_URL="https://[YOUR-PROJECT-REF].supabase.co"
# Use either anon key or publishable key (Supabase Dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_ANON_KEY="[YOUR-ANON-KEY]"
# Or new publishable key (any one of these is accepted):
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY="[YOUR-PUBLISHABLE-KEY]"
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
SUPABASE_SERVICE_ROLE_KEY="[YOUR-SERVICE-ROLE-KEY]"

# Xero OAuth2
XERO_CLIENT_ID="[YOUR-XERO-CLIENT-ID]"
XERO_CLIENT_SECRET="[YOUR-XERO-CLIENT-SECRET]"
XERO_REDIRECT_URI="http://localhost:3000/api/xero/callback"
NEXT_PUBLIC_XERO_REDIRECT_URI="http://localhost:3000/api/xero/callback"

# App URL (for OAuth callbacks - update for production)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional: after creating a user in Supabase, paste their UUID to grant management on seed
# SEED_ADMIN_USER_ID="00000000-0000-0000-0000-000000000000"

# Zoho Assist (optional — can be stored in Settings UI instead)
# Register redirect: {NEXT_PUBLIC_APP_URL}/api/settings/zoho/callback
ZOHO_CLIENT_ID=""
ZOHO_CLIENT_SECRET=""
ZOHO_REFRESH_TOKEN=""
ZOHO_DATA_CENTER="us"
