# Database — Supabase: use the SHARED POOLER, not the direct `db.*.supabase.co` string (IPv6-only; often fails on Vercel IPv4).
# Dashboard → Connect → copy URI for:
# - Vercel / serverless (required): **Transaction** pooler, port **6543** — must include pgbouncer=true for Prisma.
# - Local dev only: **Session** pooler, port **5432** — ~15 concurrent clients; do not use on Vercel (error: EMAXCONNSESSION / max clients in session mode).
#   For that session URI, do not add pgbouncer=true (per Supabase session-mode docs).
# Always add sslmode=require if the dashboard string omits it. URL-encode special chars in the password (@ → %40).
# User format is often postgres.[PROJECT-REF] — match the dashboard exactly.
#
# Production / Vercel (transaction pooler):
# pgbouncer=true is required for Prisma + port 6543 — without it you may get SQLSTATE 42P05 (prepared statement already exists).
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true&connection_limit=1"

# If `npx prisma db push` hangs or times out on port 6543, run it once with the **Session pooler** URI from
# Supabase → Connect (port 5432, same password; do not add pgbouncer=true). Example:
#   $env:DATABASE_URL="postgresql://postgres.[REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres?sslmode=require"
#   npx prisma db push
# Then restore DATABASE_URL to the 6543 transaction pooler for the Next.js app.

# SCHEMA_DRIFT / “column … does not exist” (e.g. Asset.purchaseDate): the database is behind `prisma/schema.prisma` — run `db push` as above.

# Vercel Cron (weekly Assist public IP sync): set the same value in Vercel → Project → Settings → Environment Variables.
# The cron job GET /api/cron/sync-assist-public-ip sends Authorization: Bearer <CRON_SECRET>.
CRON_SECRET=""


# Supabase (for Auth, optional client)
NEXT_PUBLIC_SUPABASE_URL="https://[YOUR-PROJECT-REF].supabase.co"
# Use either anon key or publishable key (Supabase Dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_ANON_KEY="[YOUR-ANON-KEY]"
# Or new publishable key (any one of these is accepted):
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY="[YOUR-PUBLISHABLE-KEY]"
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
# Required for Settings → Users (invite / list users via Supabase Admin API). Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY="[YOUR-SERVICE-ROLE-KEY]"

# Optional: Supabase Storage for brand logo (npm run brand:upload-supabase)
# Create a bucket in Dashboard → Storage (e.g. public bucket named "brand").
# SUPABASE_BRAND_BUCKET="brand"
# SUPABASE_BRAND_LOGO_PATH="hna-logo.png"

# Xero OAuth2
XERO_CLIENT_ID="[YOUR-XERO-CLIENT-ID]"
XERO_CLIENT_SECRET="[YOUR-XERO-CLIENT-SECRET]"
XERO_REDIRECT_URI="http://localhost:3000/api/xero/callback"
NEXT_PUBLIC_XERO_REDIRECT_URI="http://localhost:3000/api/xero/callback"

# App URL (for OAuth callbacks - update for production)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional: after creating a user in Supabase, paste their UUID to grant admin on seed
# SEED_ADMIN_USER_ID="00000000-0000-0000-0000-000000000000"

# Comma-separated emails that always resolve to super_admin (bootstrap; not stored as a DB role value)
# SUPER_ADMIN_EMAILS="shafiek@handicaps.co.za"

# Zoho Assist (optional — can be stored in Settings UI instead)
# Register redirect: {NEXT_PUBLIC_APP_URL}/api/settings/zoho/callback
ZOHO_CLIENT_ID=""
ZOHO_CLIENT_SECRET=""
ZOHO_REFRESH_TOKEN=""
ZOHO_DATA_CENTER="us"

# Resend (optional — finance notification emails; configure when domain is verified)
# Settings → Email can use "Resend REST API" (HTTPS) or "SMTP" (no REST calls).
# RESEND_API_KEY="re_..."
# RESEND_FROM_EMAIL="notifications@your-verified-domain.com"
# Alias supported:
# EMAIL_FROM="notifications@your-verified-domain.com"
# Optional explicit From when using SMTP transport:
# SMTP_FROM="notifications@your-verified-domain.com"

# SMTP (optional — use when Settings → Email transport is SMTP, e.g. Resend SMTP relay or Microsoft 365)
# SMTP_HOST="smtp.resend.com"
# SMTP_PORT="587"
# SMTP_USER="resend"
# SMTP_PASSWORD="re_..." # or your SMTP provider’s password
# SMTP_SECURE="false" # set "true" for implicit TLS (e.g. port 465)

# Zoho Desk (optional — separate OAuth client with Desk scopes; can be stored in Settings → Zoho Desk API)
# ZOHO_DESK_ORG_ID=""
# ZOHO_DESK_DEPARTMENT_ID=""
# ZOHO_DESK_CLIENT_ID=""
# ZOHO_DESK_CLIENT_SECRET=""
# ZOHO_DESK_REFRESH_TOKEN=""
# ZOHO_DESK_DATA_CENTER="us"
