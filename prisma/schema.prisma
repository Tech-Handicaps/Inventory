// Inventory Flow Control System - Prisma Schema
// Extensible asset lifecycle states; Xero sync for fixed assets + inventory

generator client {
  provider      = "prisma-client-js"
  // Windows/mac dev + Vercel (Linux) — avoids “Query engine not found” on deploy
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

/// Use a pooled URL on serverless (e.g. Supabase: port 6543, add ?pgbouncer=true).
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Extensible: add new rows to load additional states later
model DeviceTemplate {
  id             String   @id @default(cuid())
  label          String   // display name for dropdowns (e.g. "Dell Latitude 5540")
  manufacturer   String
  model          String
  category       String
  notes          String?
  /// Typical CPU for this SKU — pre-fills new assets when template is chosen
  processorName  String?
  /// Typical RAM (e.g. "16 GB") — pre-fills new assets
  systemRam      String?
  /// Typical GPU — pre-fills new assets
  systemGpu      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  assets         Asset[]

  @@unique([manufacturer, model])
}

model AssetStatus {
  id          String   @id @default(cuid())
  code        String   @unique // e.g. "new", "repair", "refurbished", "written_off"
  label       String
  description String?
  sortOrder   Int      @default(0)
  assets      Asset[]
}

model Asset {
  id                String           @id @default(cuid())
  assetName         String
  category          String
  serialNumber      String?          @unique
  manufacturer      String?
  model             String?
  deviceTemplateId  String?
  deviceTemplate    DeviceTemplate?  @relation(fields: [deviceTemplateId], references: [id], onDelete: SetNull)
  statusId          String
  status            AssetStatus      @relation(fields: [statusId], references: [id])
  reason            String?          // e.g. write-off reason
  /// manual | zoho_assist — where the row was created / primary sync source
  dataSource        String           @default("manual")
  /// Zoho Assist unattended device resource id (GET /api/v2/devices/{id})
  zohoAssistDeviceId   String?       @unique
  /// Assist org header (x-com-zoho-assist-orgid) when known — aids API calls
  zohoAssistOrgId      String?
  /// Assist department scope for this device (x-com-zoho-assist-department-id)
  zohoAssistDepartmentId String?
  /// Site / deployment location (from Assist or entered manually)
  deviceLocation    String?
  processorName     String?
  /// Human-readable RAM (e.g. "32 GB") — matches Assist where available
  systemRam         String?
  systemGpu         String?
  lastSyncedFromAssistAt DateTime?
  dateAdded         DateTime         @default(now())
  dateUpdated       DateTime         @updatedAt
  repairs           Repair[]
  xeroSyncs         XeroSync[]
}

model Repair {
  id             String   @id @default(cuid())
  assetId        String
  asset          Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  /// Human-readable case id for PDFs, audit, and cross-reference to Zoho Desk (e.g. HNA-REP-2026-A1B2C3D4)
  referenceNumber String  @unique
  repairStatus   String   // pending, in_progress, completed, cancelled
  technicianNotes String?
  zohoDeskTicketId     String? // Desk API ticket id
  zohoDeskTicketNumber   String? // Display ticket number from Desk (e.g. #12345)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model XeroSync {
  id                 String   @id @default(cuid())
  assetId            String
  asset              Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  xeroTransactionId  String?
  xeroType           String   // "fixed_asset" | "inventory"
  syncStatus         String   // pending, synced, failed, conflict
  lastSyncedAt       DateTime?
  errorMessage       String?
  createdAt          DateTime @default(now())
}

model AuditLog {
  id         String   @id @default(cuid())
  actionType String
  userId     String?
  timestamp  DateTime @default(now())
  notes      String?
  metadata   Json?    // flexible extra data
}

// App access role (see src/lib/auth/roles.ts). Stored values: admin | reports_only | accountant
// (legacy: management | accounts | operations — normalized when resolved).
// super_admin is granted only via SUPER_ADMIN_EMAILS env, not persisted as a special row value.
model UserRole {
  id       String   @id @default(cuid())
  userId   String   @unique // Supabase auth user id
  role     String
  createdAt DateTime @default(now())
}

// Zoho Assist OAuth (client credentials + refresh token stored in-app; restrict DB access in production)
model ZohoAssistSettings {
  id           String   @id @default("singleton")
  clientId     String?
  clientSecret String?
  refreshToken String?
  dataCenter   String   @default("us") // us | eu | in | au | ca | jp | sa
  /// Default x-com-zoho-assist-orgid for Assist device APIs (optional)
  defaultOrgId String?
  /// Default x-com-zoho-assist-department-id for listing / device details
  defaultDepartmentId String?
  updatedAt    DateTime @updatedAt
}

// Zoho Desk OAuth — separate from Assist; used to create/link support tickets for repairs.
model ZohoDeskSettings {
  id               String   @id @default("singleton")
  orgId            String? // Zoho Desk organization id (required for API calls)
  departmentId     String? // Default department for tickets created from inventory
  clientId         String?
  clientSecret     String?
  refreshToken     String?
  dataCenter       String   @default("us")
  updatedAt        DateTime @updatedAt
}
